// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Story {
  id                 String      @id @default(uuid())
  title              String
  description        String?
  defaultMusicTrackId String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  defaultMusicTrack  MusicTrack? @relation("StoryDefaultMusicTrack", fields: [defaultMusicTrackId], references: [id], onDelete: SetNull)
  nodes              Node[]
}

model Character {
  id        String            @id @default(uuid())
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  sprites   CharacterSprite[]
  nodes     Node[]
}

model CharacterSprite {
  id          String   @id @default(uuid())
  characterId String
  label       String
  imageUrl    String
  isDefault   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  nodes       Node[]
}

model Background {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  nodes     Node[]
}

model MusicTrack {
  id        String   @id @default(uuid())
  name      String
  audioUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stories   Story[]  @relation("StoryDefaultMusicTrack")
  nodes     Node[]   @relation("NodeMusicTrack")
}

model SiteSettings {
  id           String @id @default("global")
  publicLocale String @default("id")
}

model Node {
  id                 String   @id @default(uuid())
  storyId            String
  characterId        String?
  characterSpriteId  String?
  backgroundId       String?
  musicTrackId       String?
  editorDepth        Int      @default(0)
  editorOrder        Int      @default(0)
  text               String
  audioUrl           String?
  isStartNode        Boolean  @default(false)
  isEndNode          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  story              Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  character          Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  characterSprite    CharacterSprite? @relation(fields: [characterSpriteId], references: [id], onDelete: SetNull)
  background         Background? @relation(fields: [backgroundId], references: [id], onDelete: SetNull)
  musicTrack         MusicTrack? @relation("NodeMusicTrack", fields: [musicTrackId], references: [id], onDelete: SetNull)

  choices            Choice[]   @relation("NodeChoices")
  incomingChoices    Choice[]   @relation("ChoiceTarget")
}

model Choice {
  id            String   @id @default(uuid())
  nodeId        String    // The node this choice belongs to
  targetNodeId  String?   // The node this choice leads to
  text          String
  scoreImpact   Int      @default(0) // Political alignment/score impact
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  node          Node     @relation("NodeChoices", fields: [nodeId], references: [id], onDelete: Cascade)
  targetNode    Node?    @relation("ChoiceTarget", fields: [targetNodeId], references: [id], onDelete: SetNull)
}

model PlayerScore {
  id        String   @id @default(uuid())
  name      String
  score     Int
  createdAt DateTime @default(now())
}
